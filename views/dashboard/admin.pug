//- extends ../layout

block content
  include ../layout
  //- include ../partials/head
  //- include ../partials/sidebars
  //- include ../partials/header
  //- script(src="/js/sidebars.js" defer)
  //- script(src="/js/lucide.min.js" defer)
  if toast
    #toast-data(
      data-type=toast.type
      data-title=toast.title
      data-message=toast.message
    )

  main.dashboard-container

    .dashboard-header

      .header-content

        div
          h1 Admin Dashboard
          p Welcome, #{user.fullname || user.name} (Coordinator)

        .dashboard-tools

          a.btn-secondary(href="/admin/reports")
            | Reports
          
          a.btn-primary(href="/dashboard/admin/export")
            | Export
    br
    .stats-grid

      .stat-card.pending
        h3 Pending
        span= complaints.filter(c => c.status === "PENDING").length

      .stat-card.assigned
        h3 Assigned
        span= complaints.filter(c => c.status === "ASSIGNED").length

      .stat-card.progress
        h3 In Progress
        span= complaints.filter(c => c.status === "IN_PROGRESS").length

      .stat-card.resolved
        h3 Resolved
        span= complaints.filter(c => c.status === "RESOLVED").length

    .table-card

      .table-header

        .table-title-group
          h2 Complaint Management
          p.record-count
            = complaints.length + " Records"
        .actions
          a.btn-primary(href="/complaints/new") File New Complaint

      form(method="GET" action="/dashboard")
        .table-tools

          input.search-input(
            type="search"
            name="search"
            value=query ? query.search : ""
            placeholder="Search complaint..."
          )

          select(name="status")
            option(value="") All Statuses

            each s in statuses
              option(
                value=s
                selected=query && query.status === s
              )= s

          select(name="priority")
            option(value="") All Priorities

            each p in priorities
              option(
                value=p
                selected=query && query.priority === p
              )= p

          if user.role === "ADMIN" || user.role === "SUPERADMIN"
            select(name="department")
              option(value="") All Departments

              each dept in departments
                option(
                  value=dept.id
                  selected=query.department == dept.id
                )= dept.name

          select(name="category")
            option(value="") All Categories

            each c in categories
              option(
                value=c
                selected=query && query.category === c
              )= c

          button.btn-primary(type="submit")
            | Filter

          a.btn-secondary(href="/dashboard")
            | Reset

      br
      .table-responsive
        table.data-table

          thead

            tr
              th Id
              th Ref #
              th Complaint
              th Priority
              th Status
              th Complainant
              th Department
              th Assigned To
              th Actions

          .tbody-row
            tbody

              each complaint in complaints

                tr
                  td
                    strong= complaint.id
                  
                  td
                    strong= complaint.referenceNo

                  td
                    .table-title
                      strong= complaint.title
                      //- small= complaint.category

                  td
                    span(
                      class=`priority-badge ${complaint.priority.toLowerCase()}`
                    )
                      = complaint.priority

                  td

                    span(
                      class=`status-badge ${complaint.status.toLowerCase()}`
                    )
                      = complaint.status

                  td= complaint.complainant ? (complaint.complainant.fullname || complaint.complainant.name) : "N/A"

                  td= complaint.assignedDepartment ? complaint.assignedDepartment.name : "Unassigned"

                  td= complaint.assignedTo ? (complaint.assignedTo.fullname || complaint.assignedTo.name) : "Unassigned"

                  td

                    .actions
                      a.action-btn.view(href=`/complaints/${complaint.id}`) View
                      //- a.action-btn.assign(href=`/admin/assign?complaintId=${complaint.id}`) Assign
                      //- a.action-btn.priority(href=`/admin/priority?complaintId=${complaint.id}`) Priority
                      //- a.action-btn.status(href=`/admin/status?complaintId=${complaint.id}`) Status
                      a.action-btn.delete(href=`/complaints/${complaint.id}/delete` data-name=`${complaint.referenceNo}`) Delete

  
  include ../partials/toast
  include ../partials/footer